# AWS Beanstalk Environment Variables
# Copy these to your Beanstalk environment in AWS Console or use EB CLI

# Environment
ENV=production

# API Configuration
API_URL=http://your-beanstalk-domain.elasticbeanstalk.com
FRONTEND_URL=http://your-frontend-domain.com

# Database (DuckDB - stored on instance)
DUCKDB_PATH=/var/app/current/data/olap.duckdb

# LLM Configuration (optional)
OPENAI_API_KEY=your_openai_api_key_here
USE_HUGGINGFACE=true
HUGGINGFACE_API_KEY=your_huggingface_token_here

# AWS Configuration
AWS_REGION=us-east-1
S3_DATA_BUCKET=your-s3-bucket-name
S3_REPORTS_BUCKET=your-s3-reports-bucket-name

# Logging
LOG_LEVEL=INFO

# Application Settings
DEBUG=false
RELOAD=false
