option_settings:
  aws:autoscaling:launchconfiguration:
    EC2KeyName: ""
    SecurityGroups: ""
  aws:ec2:instances:
    InstanceTypes: t3.micro
  aws:elasticbeanstalk:xray:
    XRayEnabled: false

files:
  /opt/elasticbeanstalk/tasks/bundlelogs.d/01_python.conf:
    content: |
      /var/log/eb-engine.log
      /var/log/eb-hooks.log

container_commands:
  01_migrate_database:
    command: "cd /var/app/current && python -c 'from database.connection import init_db; print(\"Database initialized\")' || true"
    leader_only: true
    ignoreErrors: true
