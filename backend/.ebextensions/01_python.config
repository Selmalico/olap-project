option_settings:
  aws:elasticbeanstalk:container:python:
    WSGIPath: main:app
  aws:elasticbeanstalk:application:environment:
    PYTHONPATH: /var/app/current
    ENV: production
  aws:ec2:instances:
    InstanceTypes: t3.micro
  aws:elasticbeanstalk:cloudwatch:logs:
    StreamLogs: true
    DeleteOnTerminate: false
    RetentionInDays: 7

commands:
  01_install_python_dependencies:
    command: "pip install --upgrade -r requirements.txt"
    leader_only: false
  02_create_database_directory:
    command: "mkdir -p /var/app/current/data"
    ignoreErrors: true

container_commands:
  01_initialize_database:
    command: "cd /var/app/current && python -c 'from database.connection import init_db; init_db()'"
    leader_only: true
    ignoreErrors: true
